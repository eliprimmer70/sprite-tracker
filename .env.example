# Vercel Postgres connection string (get from Vercel dashboard after provisioning)
# Example: postgresql://user:password@ep-xxx.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=your_vercel_postgres_connection_string

# Random string to sign session JWTs (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here_min_32_chars

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
