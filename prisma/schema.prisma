generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trackedItems TrackedItem[]
}

model CosmeticItem {
  id            String   @id
  name          String
  description   String?
  itemType      String
  itemTypeDisplay String?
  rarity        String?
  rarityDisplay String?
  series        String?
  set           String?
  introductionChapter String?
  introductionSeason  String?
  introductionText    String?
  iconUrl       String?
  smallIconUrl  String?
  addedToApi    DateTime?
  isUnreleased  Boolean  @default(false)
  lastShopAppearance DateTime?
  shopAppearances Int    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shopHistory ShopAppearance[]

  @@index([itemType])
  @@index([rarity])
  @@index([isUnreleased])
  @@index([name])
}

model ShopAppearance {
  id        String   @id @default(uuid())
  itemId    String
  seenAt    DateTime @default(now())
  price     Int?
  section   String?

  item CosmeticItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([seenAt])
}

model TrackedItem {
  id        String   @id @default(uuid())
  userId    String
  itemName  String
  itemType  String
  iconUrl   String?
  rarity    String?
  status    String   @default("want")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemName, itemType])
  @@index([userId])
}
