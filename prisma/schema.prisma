generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items OwnedItem[]
}

model OwnedItem {
  id        String   @id @default(uuid())
  userId    String
  itemId    String
  itemType  String
  itemName  String
  iconUrl   String?
  rarity    String?
  series    String?
  addedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

model CatalogItem {
  id          String  @id
  itemType    String
  itemName    String
  iconUrl     String?
  rarity      String?
  series      String?
  description String?
  isActive    Boolean @default(true)
  updatedAt   DateTime @updatedAt

  @@index([itemType])
  @@index([isActive])
}
